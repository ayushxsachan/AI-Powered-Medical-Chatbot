ENVIRONMENT=development
LOG_LEVEL=INFO

POSTGRES_DB=medai
POSTGRES_USER=medai
POSTGRES_PASSWORD=medai
DATABASE_URL=postgresql+asyncpg://medai:medai@postgres:5432/medai

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

JWT_SECRET_KEY=change-this-to-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

BACKEND_CORS_ORIGINS=http://localhost:8501,http://frontend:8501
RATE_LIMIT_PER_MINUTE=120

OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
VECTOR_SIZE=384

INITIALIZE_KNOWLEDGE_ON_STARTUP=true
DATA_DIR=/app/data
STORAGE_DIR=/app/storage
MAX_THREAD_MESSAGES_BEFORE_SUMMARY=24
CHUNK_SIZE=900
CHUNK_OVERLAP=140

API_URL=http://backend:8000
